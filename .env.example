BOT_TOKEN=123456:telegram-bot-token
EXPECTED_BOT_USERNAME=@spotify_savers_bot

# Spotify Developer Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# Telegram user ids separated by commas.
ADMIN_IDS=123456789

# Optional: users must be members before bot sends audio.
# Examples: @top_savers_channel,-1001234567890
REQUIRED_CHANNELS=

# Optional ad settings.
AD_EVERY_N=0
AD_TEXT=
NO_ADS_USER_IDS=

# Bot storage.
DATABASE_PATH=data/bot.sqlite3
AUDIO_LIBRARY_DIR=library
COVER_CACHE_DIR=data/covers

# Branding shown in every audio caption.
BOT_PUBLIC_NAME=@spotify_savers_bot
BOT_SIGNATURE_EMOJI=💕

# Optional official/licensed audio backend.
# The bot will POST Spotify track metadata here and expects either:
# 1) an audio/* response body, or
# 2) JSON {"audio_url": "https://...", "cache_key": "optional-stable-key"}
AUTHORIZED_AUDIO_API_URL=
# Optional comma-separated fallback list. If set, the bot tries each endpoint once.
# Example: https://backend1.example/audio,https://backend2.example/audio
AUTHORIZED_AUDIO_API_URLS=
AUTHORIZED_AUDIO_API_TOKEN=
AUTHORIZED_AUDIO_TIMEOUT_SECONDS=60

# Optional YouTube Music candidate matching through YouTube Data API.
# Used only to show/search candidate matches. Audio is still sent only from
# AUDIO_LIBRARY_DIR or AUTHORIZED_AUDIO_API_URL.
YOUTUBE_MUSIC_SEARCH_ENABLED=1
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=US

# Optional VK Music metadata. Needed for vk.ru/vk.com audio links because
# public VK pages usually do not expose track title/artist to crawlers.
VK_ACCESS_TOKEN=
# Free fallback for public VK track pages: render the page with headless
# Chromium and read title/artist from the visible card.
VK_BROWSER_METADATA_ENABLED=0
VK_BROWSER_METADATA_TIMEOUT_SECONDS=18

# Album/playlist limits.
FREE_ALBUM_TRACK_LIMIT=50
PREMIUM_ALBUM_TRACK_LIMIT=500
MAX_PLAYLIST_TRACKS=50
